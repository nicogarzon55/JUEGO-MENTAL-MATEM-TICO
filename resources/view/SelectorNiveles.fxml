<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600" prefWidth="800"
            xmlns="http://javafx.com/javafx/24.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="co.edu.poli.jmm.controller.SelectorNivelController">

    <children>

        <!-- ROOT -->
        <StackPane AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
                   AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0"
                   styleClass="root">

            <children>

	<!-- 🌙 BOTÓN DARK MODE -->
	<HBox alignment="TOP_RIGHT" spacing="10"
		StackPane.alignment="TOP_RIGHT">
		<padding>
			<Insets top="15" right="20" />
		</padding>

		<children>

			<!-- ❓ REGLAS -->
			<Label text="❓" onMouseClicked="#abrirReglas"
				styleClass="theme-toggle" />

			<!-- 🌙 DARK MODE -->
			<Label fx:id="btnTema" text="🌙" styleClass="theme-toggle" />

		</children>
	</HBox>

	<!-- CARD CENTRAL -->
                <VBox alignment="CENTER"
                      spacing="30"
                      maxWidth="600"
                      styleClass="card">

                    <padding>
                        <Insets top="30" bottom="30" left="30" right="30"/>
                    </padding>

                    <!-- TITULO -->
                    <VBox alignment="CENTER" spacing="5">
                        <Label text="Descubre la Regla"
                               styleClass="label-title"/>
                        <Label text="Selecciona un nivel"
                               styleClass="label-sub"/>
                    </VBox>

                    <!-- FILA 1 -->
                    <HBox alignment="CENTER" spacing="20">

                        <VBox fx:id="nivel1Card" onMouseClicked="#irNivel"
                              alignment="CENTER" spacing="5"
                              style="-fx-background-color:#22c55e; -fx-background-radius:15;"
                              prefWidth="140" prefHeight="140">
                            <Label text="⭐" style="-fx-font-size:28"/>
                            <Label text="Nivel 1" style="-fx-text-fill:white"/>
                            <Label text="Muy Fácil" style="-fx-text-fill:white"/>
                        </VBox>

                        <VBox fx:id="nivel2Card" onMouseClicked="#irNivel"
                              alignment="CENTER" spacing="5"
                              style="-fx-background-color:#22c55e; -fx-background-radius:15;"
                              prefWidth="140" prefHeight="140">
                            <Label text="⭐" style="-fx-font-size:28"/>
                            <Label text="Nivel 2" style="-fx-text-fill:white"/>
                            <Label text="Fácil" style="-fx-text-fill:white"/>
                        </VBox>

                        <VBox fx:id="nivel3Card" onMouseClicked="#irNivel"
                              alignment="CENTER" spacing="5"
                              style="-fx-background-color:#f59e0b; -fx-background-radius:15;"
                              prefWidth="140" prefHeight="140">
                            <Label text="⭐⭐" style="-fx-font-size:28"/>
                            <Label text="Nivel 3" style="-fx-text-fill:white"/>
                            <Label text="Intermedio" style="-fx-text-fill:white"/>
                        </VBox>

                    </HBox>

                    <!-- FILA 2 -->
                    <HBox alignment="CENTER" spacing="20">

                        <VBox fx:id="nivel4Card" onMouseClicked="#irNivel"
                              alignment="CENTER" spacing="5"
                              style="-fx-background-color:#f59e0b; -fx-background-radius:15;"
                              prefWidth="140" prefHeight="140">
                            <Label text="⭐⭐" style="-fx-font-size:28"/>
                            <Label text="Nivel 4" style="-fx-text-fill:white"/>
                            <Label text="Intermedio" style="-fx-text-fill:white"/>
                        </VBox>

                        <VBox fx:id="nivel5Card" onMouseClicked="#irNivel"
                              alignment="CENTER" spacing="5"
                              style="-fx-background-color:#ef4444; -fx-background-radius:15;"
                              prefWidth="140" prefHeight="140">
                            <Label text="⭐⭐⭐" style="-fx-font-size:28"/>
                            <Label text="Nivel 5" style="-fx-text-fill:white"/>
                            <Label text="Difícil" style="-fx-text-fill:white"/>
                        </VBox>

                        <VBox fx:id="nivel6Card" onMouseClicked="#irNivel"
                              alignment="CENTER" spacing="5"
                              style="-fx-background-color:#ef4444; -fx-background-radius:15;"
                              prefWidth="140" prefHeight="140">
                            <Label text="⭐⭐⭐" style="-fx-font-size:28"/>
                            <Label text="Nivel 6" style="-fx-text-fill:white"/>
                            <Label text="Difícil" style="-fx-text-fill:white"/>
                        </VBox>

                    </HBox>

                </VBox>

            </children>
        </StackPane>

    </children>
</AnchorPane>