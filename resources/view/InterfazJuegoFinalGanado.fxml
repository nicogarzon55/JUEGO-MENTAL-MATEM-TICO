<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="650" prefWidth="800" style="-fx-background-color: linear-gradient(to bottom right, #ecfdf5, #d1fae5);" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.edu.poli.jmm.controller.ResultadoController">

    <!-- BOTÓN TEMA (ARRIBA DERECHA) -->
    <top>
        <HBox alignment="CENTER_RIGHT" style="-fx-padding: 20;">
            <Button fx:id="btnTema" prefHeight="45" prefWidth="45" style="-fx-background-radius: 25;                            -fx-font-size: 16px;" text="🌙" />
        </HBox>
    </top>

    <!-- CONTENIDO CENTRAL -->
    <center>
        <VBox alignment="TOP_CENTER" spacing="20" style="-fx-padding: 20;">

            <!-- Emoji -->
            <Label style="-fx-font-size: 80px;" text="🎉" />

            <!-- Título -->
            <Label style="-fx-font-size: 36px;                           -fx-font-weight: bold;                           -fx-text-fill: #16a34a;" text="¡Gran trabajo!" />

            <!-- Subtítulo -->
            <Label style="-fx-font-size: 16px;                           -fx-text-fill: #4b5563;" text="¡Felicitaciones, has finalizado el juego satisfactoriamente, esperamos que te hayas divertido!" />

            <!-- TABLA -->
            <TableView fx:id="tablaResultados" prefHeight="158.0" prefWidth="607.0" style="-fx-background-radius: 20;                               -fx-border-radius: 20;">

                <columns>
                    <TableColumn fx:id="colEntrada" prefWidth="300" text="Entrada" />

                    <TableColumn fx:id="colSalida" prefWidth="300" text="Salida" />
                </columns>

            </TableView>

        </VBox>
    </center>

    <!-- BOTONES INFERIORES -->
    <bottom>
        <HBox alignment="CENTER" spacing="40" style="-fx-padding: 30;">

            <Button fx:id="btn_puntaje" onAction="#verPuntaje" prefHeight="50" prefWidth="200" style="-fx-background-color: #2563eb;                            -fx-text-fill: white;                            -fx-font-size: 16px;                            -fx-background-radius: 25;" text="Consultar Puntaje" />

        </HBox>
    </bottom>

</BorderPane>
