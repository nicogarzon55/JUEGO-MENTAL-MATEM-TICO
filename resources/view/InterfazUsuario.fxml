<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600.0" prefWidth="800.0"
            xmlns="http://javafx.com/javafx/24.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="co.edu.poli.jmm.controller.UsuarioController">

   <children>

      <!-- ROOT -->
      <StackPane AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
                 AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
                 styleClass="root">

         <children>

            <!-- 🔥 BOTONES SUPERIORES -->
            <HBox alignment="TOP_RIGHT"
                  spacing="10"
                  StackPane.alignment="TOP_RIGHT">

               <padding>
                  <Insets top="15" right="20"/>
               </padding>

               <children>

                  <!-- 🌙 DARK MODE -->
                  <Label fx:id="btnTema"
                         text="🌙"
                         styleClass="theme-toggle"/>

                  <!-- ❓ REGLAS -->
                  <Label text="❓"
                         onMouseClicked="#abrirReglas"
                         styleClass="theme-toggle"/>

               </children>
            </HBox>

            <!-- CARD -->
            <VBox maxWidth="400"
                  spacing="18"
                  alignment="CENTER"
                  styleClass="card">

               <padding>
                  <Insets bottom="30" left="30" right="30" top="30"/>
               </padding>

               <!-- TITULO -->
               <VBox alignment="CENTER" spacing="5">
                  <children>
                     <Label text="BIENVENIDO!!!"
                            styleClass="label-title"/>
                     <Label text="Por favor, ingrese su nombre"
                            styleClass="label-sub"/>
                  </children>
               </VBox>

               <!-- INPUT -->
               <VBox spacing="5">
                  <children>
                     <Label text="Su nombre:"
                            styleClass="label-sub"/>
                     <TextField fx:id="txf_nameuser"
                                promptText="Ingrese su nombre..."
                                styleClass="text-field"/>
                  </children>
               </VBox>

               <!-- SALUDO -->
               <VBox fx:id="vbox_inicio"
                     alignment="CENTER"
                     spacing="5"
                     styleClass="card">

                  <padding>
                     <Insets bottom="15" left="15" right="15" top="15"/>
                  </padding>

                  <children>
                     <Label text="Hola,"
                            styleClass="label-sub"/>
                     <Label fx:id="nameLabel"
                            text="Usuario"
                            styleClass="label-title"/>
                  </children>
               </VBox>

               <!-- BOTÓN -->
               <Button fx:id="btn_jugar"
                       text="Jugar"
                       onAction="#iniciarJuego"
                       styleClass="button-primary"/>

            </VBox>

         </children>
      </StackPane>
   </children>
</AnchorPane>