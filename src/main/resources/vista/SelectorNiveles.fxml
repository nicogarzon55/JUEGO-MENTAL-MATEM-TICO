<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.GridPane?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <StackPane style="-fx-background-color: linear-gradient(to bottom right, #111827, #1f2937);" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <!-- Área demarcada y centrada -->
            <VBox spacing="20.0" alignment="CENTER"
                  style="-fx-background-color: #1f2937; -fx-background-radius: 20; -fx-border-color: #374151; -fx-border-radius: 20; -fx-border-width: 2;"
                  maxWidth="500" StackPane.alignment="CENTER">
               <children>
                  <!-- Título -->
                  <VBox alignment="CENTER" spacing="5.0">
                     <children>
                        <Label style="-fx-text-fill: white; -fx-font-size: 26; -fx-font-weight: bold;" text="Selector de nivel" />
                        <Label style="-fx-text-fill: #9ca3af;" text="Seleccione el nivel por el cual desea empezar" />
                     </children>
                  </VBox>

                  <!-- Botones organizados en GridPane -->
                  <GridPane hgap="15" vgap="15" alignment="CENTER">
                     <children>
                        <!-- Primera fila -->
                        <Button text="Nivel 1" GridPane.rowIndex="0" GridPane.columnIndex="0"
                                style="-fx-background-color: linear-gradient(to right,#6366f1, #8b5cf6); -fx-text-fill: White; -fx-font-size: 14; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand;" />
                        <Button text="Nivel 2" GridPane.rowIndex="0" GridPane.columnIndex="1"
                                style="-fx-background-color: linear-gradient(to right,#6366f1, #8b5cf6); -fx-text-fill: White; -fx-font-size: 14; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand;" />
                        <Button text="Nivel 3" GridPane.rowIndex="0" GridPane.columnIndex="2"
                                style="-fx-background-color: linear-gradient(to right,#6366f1, #8b5cf6); -fx-text-fill: White; -fx-font-size: 14; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand;" />

                        <!-- Segunda fila -->
                        <Button text="Nivel 4" GridPane.rowIndex="1" GridPane.columnIndex="0"
                                style="-fx-background-color: linear-gradient(to right,#6366f1, #8b5cf6); -fx-text-fill: White; -fx-font-size: 14; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand;" />
                        <Button text="Nivel 5" GridPane.rowIndex="1" GridPane.columnIndex="1"
                                style="-fx-background-color: linear-gradient(to right,#6366f1, #8b5cf6); -fx-text-fill: White; -fx-font-size: 14; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand;" />
                        <Button text="Nivel 6" GridPane.rowIndex="1" GridPane.columnIndex="2"
                                style="-fx-background-color: linear-gradient(to right,#6366f1, #8b5cf6); -fx-text-fill: White; -fx-font-size: 14; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand;" />

                        <!-- Tercera fila (centrado) -->
                        <Button text="Nivel 7" GridPane.rowIndex="2" GridPane.columnIndex="1"
                                style="-fx-background-color: linear-gradient(to right,#6366f1, #8b5cf6); -fx-text-fill: White; -fx-font-size: 14; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand;" />
                     </children>
                  </GridPane>
               </children>
               <padding>
                  <Insets top="30" right="30" bottom="30" left="30"/>
               </padding>
            </VBox>
         </children>
      </StackPane>
   </children>
</AnchorPane>