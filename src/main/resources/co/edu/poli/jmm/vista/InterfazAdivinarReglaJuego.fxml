<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="650.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.edu.poli.jmm.controladores.AdivinarReglaController">

   <children>
      <StackPane style="-fx-background-color: linear-gradient(to bottom right, #111827, #1f2937);" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <VBox alignment="TOP_CENTER" maxWidth="1000.0" prefWidth="1000.0" spacing="30.0">
               <padding>
                  <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
               </padding>

               <!-- HEADER -->
               <HBox alignment="CENTER_LEFT" spacing="20.0">
                  <HBox alignment="CENTER_LEFT" spacing="15.0">
                     <children>
                        <Button onAction="#onVolver" style="-fx-background-color: #4b5563; -fx-text-fill: white; -fx-font-size: 16;                                        -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand;" text="←" />
                        <Label fx:id="lblNivel" style="-fx-font-size: 22; -fx-text-fill: white; -fx-font-weight: bold;" text="Nivel 1 – Descubre la Regla" />
                     </children>
                  </HBox>
                  <Pane HBox.hgrow="ALWAYS" />
                  <!-- Puntaje visible -->
                  <Label fx:id="lblPuntaje" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #7c3aed;" text="Puntos: 10" />
               </HBox>

               <!-- CONTENIDO PRINCIPAL -->
               <HBox alignment="CENTER" spacing="35.0">

                  <!-- INPUT CARD -->
                  <VBox alignment="CENTER" prefWidth="330.0" spacing="20.0" style="-fx-background-color: #1f2937; -fx-background-radius: 20;                                -fx-border-color: #374151; -fx-border-radius: 20; -fx-border-width: 2;                                -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 15, 0, 0, 5);">
                     <padding>
                        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
                     </padding>
                     <children>
                        <Label style="-fx-text-fill: #FFFFFF; -fx-font-size: 14;" text="ENTRADA" />
                        <HBox alignment="CENTER" spacing="15.0">
                           <children>
                              <TextField fx:id="txtEntrada" alignment="CENTER" prefWidth="100.0" promptText="0" style="-fx-font-size: 20; -fx-background-color: #374151;                                                 -fx-text-fill: white; -fx-prompt-text-fill: #9ca3af;                                                 -fx-background-radius: 12; -fx-border-radius: 12;                                                 -fx-border-color: #4b5563;" />
                              <Button fx:id="btnIngresar" onAction="#onIngresar" prefHeight="40.0" prefWidth="155.0" style="-fx-background-color: linear-gradient(to right,#6366f1, #8b5cf6);                                              -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold;                                              -fx-background-radius: 12; -fx-cursor: hand;                                              -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 10,0,0,3);" text="INGRESAR!">
                                 <padding>
                                    <Insets bottom="10.0" left="25.0" right="25.0" top="10.0" />
                                 </padding>
                              </Button>
                           </children>
                        </HBox>
                     </children>
                  </VBox>

                  <!-- TABLA -->
                  <VBox prefWidth="620.0" style="-fx-background-color: #1f2937; -fx-background-radius: 20;                                -fx-border-color: #374151; -fx-border-radius: 20; -fx-border-width: 2;                                -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 15, 0, 0, 5);">
                     <children>
                        <TableView fx:id="tablaVista" prefHeight="460.0" prefWidth="580.0" style="-fx-background-color: #1f2937;                                           -fx-control-inner-background: #1f2937;                                           -fx-table-cell-border-color: #374151;                                           -fx-text-background-color: #e5e7eb;                                           -fx-font-size: 16;">
                           <columns>
                              <TableColumn fx:id="colEntrada" prefWidth="290.0" style="-fx-alignment: CENTER;" text="ENTRADA" />
                              <TableColumn fx:id="colSalida" prefWidth="290.0" style="-fx-alignment: CENTER;" text="SALIDA" />
                           </columns>
                        </TableView>
                     </children>
                  </VBox>

               </HBox>

               <!-- BOTON INFERIOR -->
               <HBox alignment="CENTER">
                  <children>
                     <Button fx:id="btnConozcaRegla" onAction="#onConozcaRegla" style="-fx-background-color: linear-gradient(to right,#6366f1, #8b5cf6); -fx-text-fill: white;                                     -fx-font-weight: bold; -fx-font-size: 16;                                     -fx-background-radius: 25; -fx-cursor: hand;                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 10,0,0,3);" text="¡Creo que conozco la regla!">
                        <padding>
                           <Insets bottom="12.0" left="35.0" right="35.0" top="12.0" />
                        </padding>
                     </Button>
                  </children>
               </HBox>

            </VBox>
         </children>
      </StackPane>
   </children>
</AnchorPane>
