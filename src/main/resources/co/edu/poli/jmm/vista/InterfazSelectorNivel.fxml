<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="800.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="co.edu.poli.jmm.controladores.SelectorNivelController">
   <children>
      <StackPane style="-fx-background-color: linear-gradient(to bottom right, #111827, #1f2937);"
                 AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                 AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <VBox alignment="CENTER" maxWidth="520" spacing="24.0"
                  style="-fx-background-color: #1f2937; -fx-background-radius: 20;
                         -fx-border-color: #374151; -fx-border-radius: 20; -fx-border-width: 2;"
                  StackPane.alignment="CENTER">
               <children>

                  <!-- Encabezado: título + botón de reglas -->
                  <HBox alignment="CENTER" spacing="12.0">
                     <children>
                        <VBox alignment="CENTER" spacing="5.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label style="-fx-text-fill: white; -fx-font-size: 26; -fx-font-weight: bold;"
                                     text="Selector de Nivel" />
                              <Label style="-fx-text-fill: #9ca3af;"
                                     text="Seleccione el nivel por el cual desea empezar" />
                           </children>
                        </VBox>

                        <!-- Botón Reglas del Juego -->
                        <Button onAction="#abrirReglas"
                                text="📖 Reglas"
                                style="-fx-background-color: transparent;
                                       -fx-text-fill: #a78bfa;
                                       -fx-font-size: 14;
                                       -fx-font-weight: bold;
                                       -fx-border-color: #6366f1;
                                       -fx-border-radius: 12;
                                       -fx-background-radius: 12;
                                       -fx-cursor: hand;
                                       -fx-padding: 6 14 6 14;" />
                     </children>
                  </HBox>

                  <!-- Separador visual -->
                  <HBox style="-fx-background-color: #374151; -fx-min-height: 1; -fx-max-height: 1;" />

                  <!-- Grid de botones de nivel -->
                  <GridPane alignment="CENTER" hgap="15" vgap="15">
                     <children>
                        <!-- Fila 1 -->
                        <Button fx:id="btn_level1" onAction="#irNivel1"
                                prefWidth="150" prefHeight="56"
                                style="-fx-background-color: linear-gradient(to right,#6366f1, #8b5cf6);
                                       -fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;
                                       -fx-background-radius: 12; -fx-cursor: hand;
                                       -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 10,0,0,3);"
                                text="⭐ Nivel 1"
                                GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <Button fx:id="btn_level2" onAction="#irNivel2"
                                prefWidth="150" prefHeight="56"
                                style="-fx-background-color: linear-gradient(to right,#6366f1, #8b5cf6);
                                       -fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;
                                       -fx-background-radius: 12; -fx-cursor: hand;
                                       -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 10,0,0,3);"
                                text="⭐ Nivel 2"
                                GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        <Button fx:id="btn_level3" onAction="#irNivel3"
                                prefWidth="150" prefHeight="56"
                                style="-fx-background-color: linear-gradient(to right,#6366f1, #8b5cf6);
                                       -fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;
                                       -fx-background-radius: 12; -fx-cursor: hand;
                                       -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 10,0,0,3);"
                                text="🌟 Nivel 3"
                                GridPane.columnIndex="2" GridPane.rowIndex="0" />

                        <!-- Fila 2 -->
                        <Button fx:id="btn_level4" onAction="#irNivel4"
                                prefWidth="150" prefHeight="56"
                                style="-fx-background-color: linear-gradient(to right,#6366f1, #8b5cf6);
                                       -fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;
                                       -fx-background-radius: 12; -fx-cursor: hand;
                                       -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 10,0,0,3);"
                                text="🌟 Nivel 4"
                                GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <Button fx:id="btn_level5" onAction="#irNivel5"
                                prefWidth="150" prefHeight="56"
                                style="-fx-background-color: linear-gradient(to right,#6366f1, #8b5cf6);
                                       -fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;
                                       -fx-background-radius: 12; -fx-cursor: hand;
                                       -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 10,0,0,3);"
                                text="🔥 Nivel 5"
                                GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        <Button fx:id="btn_level6" onAction="#irNivel6"
                                prefWidth="150" prefHeight="56"
                                style="-fx-background-color: linear-gradient(to right,#6366f1, #8b5cf6);
                                       -fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;
                                       -fx-background-radius: 12; -fx-cursor: hand;
                                       -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 10,0,0,3);"
                                text="🔥 Nivel 6"
                                GridPane.columnIndex="2" GridPane.rowIndex="1" />

                        <!-- Fila 3 — centrado -->
                        <Button fx:id="btn_level7" onAction="#irNivel7"
                                prefWidth="150" prefHeight="56"
                                style="-fx-background-color: linear-gradient(to right,#6366f1, #8b5cf6);
                                       -fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;
                                       -fx-background-radius: 12; -fx-cursor: hand;
                                       -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 10,0,0,3);"
                                text="💀 Nivel 7"
                                GridPane.columnIndex="1" GridPane.rowIndex="2" />
                     </children>
                     <columnConstraints>
                        <ColumnConstraints minWidth="130" />
                        <ColumnConstraints minWidth="130" />
                        <ColumnConstraints minWidth="130" />
                     </columnConstraints>
                     <rowConstraints>
                        <RowConstraints minHeight="50" />
                        <RowConstraints minHeight="50" />
                        <RowConstraints minHeight="50" />
                     </rowConstraints>
                  </GridPane>

                  <!-- Leyenda de dificultad -->
                  <HBox alignment="CENTER" spacing="20">
                     <children>
                        <Label style="-fx-text-fill: #9ca3af; -fx-font-size: 12;" text="⭐ Fácil (1-2)" />
                        <Label style="-fx-text-fill: #9ca3af; -fx-font-size: 12;" text="🌟 Medio (3-4)" />
                        <Label style="-fx-text-fill: #9ca3af; -fx-font-size: 12;" text="🔥💀 Difícil (5-7)" />
                     </children>
                  </HBox>

               </children>
               <padding>
                  <Insets bottom="35" left="35" right="35" top="30" />
               </padding>
            </VBox>
         </children>
      </StackPane>
   </children>
</AnchorPane>
