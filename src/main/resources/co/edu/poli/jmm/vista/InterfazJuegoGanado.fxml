<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="650" prefWidth="800" style="-fx-background-color: linear-gradient(to bottom right, #111827, #1f2937);" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.edu.poli.jmm.controladores.JuegoGanadoController">

    <!-- BOTÓN TEMA (ARRIBA DERECHA) -->
    <top>
        <HBox alignment="CENTER_RIGHT" style="-fx-padding: 20;">
            <Button fx:id="btnTema" onAction="#onToggleTema" prefHeight="45" prefWidth="45" style="-fx-background-color: #4b5563; -fx-text-fill: white;                            -fx-background-radius: 25; -fx-font-size: 16px;                            -fx-font-weight: bold; -fx-cursor: hand;" text="🌙" />
        </HBox>
    </top>

    <!-- CONTENIDO CENTRAL -->
    <center>
        <VBox alignment="TOP_CENTER" spacing="20" style="-fx-padding: 20;">

            <Label style="-fx-font-size: 80px;" text="🎉" />

            <Label style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #34d399;" text="¡Gran trabajo!" />

            <Label fx:id="lblTitulo" style="-fx-font-size: 16px; -fx-text-fill: #d1d5db;" text="¡Has completado correctamente todos los valores!" />

            <Label fx:id="lblPuntaje" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #7c3aed;" text="Puntaje: 0" />

            <VBox alignment="CENTER" prefHeight="420" prefWidth="760" style="-fx-background-color: #1f2937; -fx-background-radius: 20;                          -fx-border-color: #374151; -fx-border-radius: 20; -fx-border-width: 2;                          -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 15, 0, 0, 5); -fx-padding: 20;">
                <TableView fx:id="tablaResultados" prefHeight="380" prefWidth="716.0" style="-fx-background-color: #1f2937;                                   -fx-control-inner-background: #1f2937;                                   -fx-table-cell-border-color: #374151;                                   -fx-text-background-color: #e5e7eb;                                   -fx-font-size: 16;">
                    <columns>
                        <TableColumn fx:id="colEntrada" prefWidth="360" style="-fx-alignment: CENTER;" text="ENTRADA" />
                        <TableColumn fx:id="colSalida" prefWidth="360" style="-fx-alignment: CENTER;" text="SALIDA" />
                    </columns>
                </TableView>
            </VBox>

        </VBox>
    </center>

    <!-- BOTONES INFERIORES -->
    <bottom>
        <HBox alignment="CENTER" spacing="40" style="-fx-padding: 30;">

            <Button onAction="#onIntentoNuevo" prefHeight="50" prefWidth="200" style="-fx-background-color: #4b5563; -fx-text-fill: white;                            -fx-font-size: 16px; -fx-font-weight: bold;                            -fx-background-radius: 25; -fx-cursor: hand;" text="Intento Nuevo" />

            <Button fx:id="btnSiguienteNivel" onAction="#onSiguienteNivel" prefHeight="50" prefWidth="200" style="-fx-background-color: linear-gradient(to right,#6366f1, #8b5cf6);                            -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;                            -fx-background-radius: 25; -fx-cursor: hand;                            -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 10,0,0,3);" text="Siguiente Nivel" />

        </HBox>
    </bottom>

</BorderPane>
