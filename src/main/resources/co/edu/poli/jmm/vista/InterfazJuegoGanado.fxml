<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="680" prefWidth="800"
            style="-fx-background-color: linear-gradient(to bottom right, #111827, #1f2937);"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="co.edu.poli.jmm.controladores.JuegoGanadoController">

    <!-- BOTÓN TEMA (ARRIBA DERECHA) -->
    <top>
        <HBox alignment="CENTER_RIGHT" style="-fx-padding: 15;">
            <Button fx:id="btnTema" onAction="#onToggleTema"
                    prefHeight="45" prefWidth="45" text="🌙"
                    style="-fx-background-color: #4b5563; -fx-text-fill: white;
                           -fx-background-radius: 25; -fx-font-size: 16px;
                           -fx-font-weight: bold; -fx-cursor: hand;" />
        </HBox>
    </top>

    <!-- CONTENIDO CENTRAL -->
    <center>
        <VBox alignment="TOP_CENTER" spacing="10" style="-fx-padding: 0 20 0 20;">

            <Label style="-fx-font-size: 55px;" text="🎉" />

            <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #34d399;"
                   text="¡Gran trabajo!" />

            <Label fx:id="lblTitulo"
                   style="-fx-font-size: 14px; -fx-text-fill: #d1d5db;"
                   text="¡Has completado correctamente todos los valores!" />

            <Label fx:id="lblPuntaje"
                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #7c3aed;"
                   text="Puntaje: 0" />

            <!-- BOTÓN VER PUNTAJE -->
            <Button fx:id="btnVerPuntaje" onAction="#onVerPuntaje"
                    prefHeight="36" prefWidth="220" text="¿Quieres ver tu puntaje?"
                    style="-fx-background-color: transparent;
                           -fx-border-color: #6366f1; -fx-border-width: 2; -fx-border-radius: 18;
                           -fx-background-radius: 18; -fx-text-fill: #a5b4fc;
                           -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;" />

            <!-- PANEL PUNTAJE FINAL (oculto por defecto) -->
            <VBox fx:id="panelPuntajeFinal" alignment="CENTER" spacing="4"
                  managed="false" visible="false"
                  style="-fx-background-color: #111827;
                         -fx-background-radius: 14;
                         -fx-border-color: #6366f1; -fx-border-radius: 14; -fx-border-width: 2;
                         -fx-effect: dropshadow(gaussian, rgba(99,102,241,0.45), 16, 0, 0, 0);
                         -fx-padding: 16;">
                <VBox.margin>
                    <Insets left="150" right="150" />
                </VBox.margin>

                <Label style="-fx-font-size: 18px;" text="🏆" />
                <Label style="-fx-font-size: 11px; -fx-text-fill: #9ca3af; -fx-font-weight: bold;"
                       text="PUNTAJE FINAL" />
                <Label fx:id="lblPuntajeFinal"
                       style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #a78bfa;"
                       text="0" />
                <Label fx:id="lblMensajePuntaje"
                       style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"
                       text="¡Excelente desempeño!" />
            </VBox>

            <!-- TABLA RESULTADOS -->
            <VBox alignment="CENTER"
                  style="-fx-background-color: #1f2937; -fx-background-radius: 16;
                         -fx-border-color: #374151; -fx-border-radius: 16; -fx-border-width: 2;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 12, 0, 0, 4);
                         -fx-padding: 15;"
                  VBox.vgrow="ALWAYS">
                <TableView fx:id="tablaResultados"
                           prefWidth="720" prefHeight="220"
                           style="-fx-background-color: #1f2937;
                                  -fx-control-inner-background: #1f2937;
                                  -fx-table-cell-border-color: #374151;
                                  -fx-text-background-color: #e5e7eb;
                                  -fx-font-size: 15;">
                    <columns>
                        <TableColumn fx:id="colEntrada" prefWidth="358"
                                     style="-fx-alignment: CENTER;" text="ENTRADA" />
                        <TableColumn fx:id="colSalida"  prefWidth="358"
                                     style="-fx-alignment: CENTER;" text="SALIDA" />
                    </columns>
                </TableView>
            </VBox>

        </VBox>
    </center>

    <!-- BOTONES INFERIORES -->
    <bottom>
        <HBox alignment="CENTER" spacing="30" style="-fx-padding: 18;">

            <Button onAction="#onIntentoNuevo"
                    prefHeight="46" prefWidth="180" text="Intento Nuevo"
                    style="-fx-background-color: #4b5563; -fx-text-fill: white;
                           -fx-font-size: 15px; -fx-font-weight: bold;
                           -fx-background-radius: 23; -fx-cursor: hand;" />

            <Button fx:id="btnSiguienteNivel" onAction="#onSiguienteNivel"
                    prefHeight="46" prefWidth="180" text="Siguiente Nivel"
                    style="-fx-background-color: linear-gradient(to right, #6366f1, #8b5cf6);
                           -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold;
                           -fx-background-radius: 23; -fx-cursor: hand;
                           -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 8, 0, 0, 3);" />
        </HBox>
    </bottom>

</BorderPane>