<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/17"
            fx:controller="co.edu.poli.jmm.controladores.JuegoPrincipalController"
            prefWidth="800" prefHeight="600">

    <!-- HEADER -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15"
              style="-fx-padding: 20; -fx-background-color: linear-gradient(to right, #eef2ff, #e0e7ff);">

            <Button text="←" prefWidth="40" prefHeight="40"
                    onAction="#onRegresar"
                    style="-fx-background-radius: 20;"/>

            <Label fx:id="lblNivel"
                   text="Nivel 1 – Completa los valores de Salida"
                   style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="lblPuntaje"
                   text="Puntos: 10"
                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #7c3aed;"/>

            <Button fx:id="btnTema" text="🌙" prefWidth="45" prefHeight="45"
                    onAction="#onToggleTema"
                    style="-fx-background-radius: 25; -fx-font-size: 16px;"/>
        </HBox>
    </top>

    <!-- TABLA EDITABLE -->
    <center>
        <VBox alignment="CENTER" spacing="20" style="-fx-padding: 30;">
            <TableView fx:id="tabla" prefWidth="650" prefHeight="350"
                       editable="true"
                       style="-fx-background-radius: 20; -fx-border-radius: 20;">
                <columns>
                    <TableColumn fx:id="colEntrada" text="Entrada" prefWidth="325"/>
                    <TableColumn fx:id="colSalida"  text="Salida (escribe aquí)" prefWidth="325" editable="true"/>
                </columns>
            </TableView>
        </VBox>
    </center>

    <!-- BOTONES INFERIORES -->
    <bottom>
        <HBox alignment="CENTER" spacing="40" style="-fx-padding: 25;">

            <Button text="← Regresa y prueba más entradas"
                    prefWidth="260" prefHeight="50"
                    onAction="#onRegresar"
                    style="-fx-background-color: #4b5563; -fx-text-fill: white;
                           -fx-background-radius: 25;"/>

            <Button text="✓ Revisa mis respuestas"
                    prefWidth="220" prefHeight="50"
                    onAction="#onRevisarRespuestas"
                    style="-fx-background-color: #16a34a; -fx-text-fill: white;
                           -fx-background-radius: 25;"/>
        </HBox>
    </bottom>

</BorderPane>
